{
	"name": "@scottlz0310/renovate-config-init",
	"version": "2.4.0",
	"description": "CLI tool to initialize Renovate configuration with auto-detection",
	"type": "module",
	"bin": {
		"renovate-config-init": "dist/index.js"
	},
	"files": [
		"dist",
		"presets"
	],
	"scripts": {
		"build": "tsc",
		"dev": "tsx src/index.ts",
		"tsc:check": "tsc --noEmit",
		"test": "vitest run --root ./ --dir ./test --maxWorkers 1 --no-file-parallelism",
		"test:coverage": "vitest run --root ./ --dir ./test --maxWorkers 1 --no-file-parallelism --coverage.enabled --coverage.provider=v8 --coverage.reporter=text --coverage.reporter=lcov",
		"validate": "bun scripts/validate-presets.js",
		"lint": "biome ci .",
		"format": "biome format --write .",
		"knip": "knip --no-config-hints",
		"check:ci": "bun run tsc:check && bun run lint && bun run knip && bun run validate && bun run test"
	},
	"keywords": [
		"renovate",
		"renovate-config",
		"shareable-config",
		"dependencies",
		"cli",
		"init"
	],
	"author": "scottlz0310",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/scottlz0310/renovate-config.git"
	},
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@clack/prompts": "^1.7.0",
		"fast-glob": "^3.3.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.4",
		"@types/node": "^26.1.1",
		"@vitest/coverage-v8": "^4.1.10",
		"ajv": "^8.20.0",
		"ajv-formats": "^3.0.1",
		"knip": "^6.26.0",
		"lefthook": "^2.1.10",
		"renovate": "^43.260.3",
		"tsx": "^4.23.1",
		"typescript": "^7.0.2",
		"vitest": "^4.1.10"
	},
	"trustedDependencies": [
		"core-js-pure",
		"dtrace-provider",
		"esbuild",
		"lefthook",
		"protobufjs",
		"re2"
	],
	"engines": {
		"node": ">=24.18.0"
	}
}
