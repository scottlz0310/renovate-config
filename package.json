{
	"name": "@scottlz0310/renovate-config-init",
	"version": "2.3.0",
	"description": "CLI tool to initialize Renovate configuration with auto-detection",
	"type": "module",
	"bin": {
		"renovate-config-init": "dist/index.js"
	},
	"files": [
		"dist",
		"presets"
	],
	"scripts": {
		"build": "tsc",
		"dev": "tsx src/index.ts",
		"tsc:check": "tsc --noEmit",
		"test": "vitest run --root ./ --dir ./test --maxWorkers 1 --no-file-parallelism",
		"test:coverage": "vitest run --root ./ --dir ./test --maxWorkers 1 --no-file-parallelism --coverage.enabled --coverage.provider=v8 --coverage.reporter=text --coverage.reporter=lcov",
		"validate": "node scripts/validate-presets.js",
		"lint": "biome ci .",
		"format": "biome format --write .",
		"knip": "knip --no-config-hints",
		"check:ci": "pnpm run tsc:check && pnpm run lint && pnpm run knip && pnpm run validate && pnpm run test"
	},
	"keywords": [
		"renovate",
		"renovate-config",
		"shareable-config",
		"dependencies",
		"cli",
		"init"
	],
	"author": "scottlz0310",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/scottlz0310/renovate-config.git"
	},
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@clack/prompts": "^1.7.0",
		"fast-glob": "^3.3.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.3",
		"@types/node": "^24.13.3",
		"@vitest/coverage-v8": "^4.1.10",
		"ajv": "^8.20.0",
		"ajv-formats": "^3.0.1",
		"knip": "^6.24.0",
		"lefthook": "^2.1.10",
		"renovate": "^43.255.2",
		"tsx": "^4.23.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.10"
	},
	"packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8",
	"engines": {
		"node": ">=24.18.0"
	}
}
