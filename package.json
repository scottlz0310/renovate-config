{
	"name": "@scottlz0310/renovate-config-init",
	"version": "2.2.0",
	"description": "CLI tool to initialize Renovate configuration with auto-detection",
	"type": "module",
	"bin": {
		"renovate-config-init": "./dist/index.js"
	},
	"files": [
		"dist",
		"presets"
	],
	"scripts": {
		"build": "tsc",
		"dev": "tsx src/index.ts",
		"tsc:check": "tsc --noEmit",
		"test": "vitest run --root ./ --dir ./test --maxWorkers 1 --no-file-parallelism",
		"test:coverage": "vitest run --root ./ --dir ./test --maxWorkers 1 --no-file-parallelism --coverage.enabled --coverage.provider=v8 --coverage.reporter=text --coverage.reporter=lcov",
		"validate": "node scripts/validate-presets.js",
		"lint": "biome ci .",
		"format": "biome format --write .",
		"knip": "knip --no-config-hints",
		"check:ci": "pnpm run tsc:check && pnpm run lint && pnpm run knip && pnpm run validate && pnpm run test"
	},
	"keywords": [
		"renovate",
		"renovate-config",
		"shareable-config",
		"dependencies",
		"cli",
		"init"
	],
	"author": "scottlz0310",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/scottlz0310/renovate-config.git"
	},
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@clack/prompts": "^1.2.0",
		"fast-glob": "^3.3.3"
	},
	"devDependencies": {
		"@vitest/coverage-v8": "^4.1.5",
		"@biomejs/biome": "^2.4.14",
		"@types/node": "^24.12.2",
		"ajv": "^8.20.0",
		"ajv-formats": "^3.0.1",
		"knip": "^6.7.0",
		"lefthook": "^2.1.6",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	},
	"packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
	"engines": {
		"node": ">=24.15.0"
	}
}
