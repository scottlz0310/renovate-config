{
	"name": "@scottlz0310/renovate-config-init",
	"version": "2.2.2",
	"description": "CLI tool to initialize Renovate configuration with auto-detection",
	"type": "module",
	"bin": {
		"renovate-config-init": "dist/index.js"
	},
	"files": [
		"dist",
		"presets"
	],
	"scripts": {
		"build": "tsc",
		"dev": "tsx src/index.ts",
		"tsc:check": "tsc --noEmit",
		"test": "vitest run --root ./ --dir ./test --maxWorkers 1 --no-file-parallelism",
		"test:coverage": "vitest run --root ./ --dir ./test --maxWorkers 1 --no-file-parallelism --coverage.enabled --coverage.provider=v8 --coverage.reporter=text --coverage.reporter=lcov",
		"validate": "node scripts/validate-presets.js",
		"lint": "biome ci .",
		"format": "biome format --write .",
		"knip": "knip --no-config-hints",
		"check:ci": "pnpm run tsc:check && pnpm run lint && pnpm run knip && pnpm run validate && pnpm run test"
	},
	"keywords": [
		"renovate",
		"renovate-config",
		"shareable-config",
		"dependencies",
		"cli",
		"init"
	],
	"author": "scottlz0310",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/scottlz0310/renovate-config.git"
	},
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@clack/prompts": "^1.6.0",
		"fast-glob": "^3.3.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.1",
		"@types/node": "^24.13.2",
		"@vitest/coverage-v8": "^4.1.9",
		"ajv": "^8.20.0",
		"ajv-formats": "^3.0.1",
		"knip": "^6.20.0",
		"lefthook": "^2.1.9",
		"renovate": "^43.243.2",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"vitest": "^4.1.9"
	},
	"packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
	"engines": {
		"node": ">=24.18.0"
	}
}
